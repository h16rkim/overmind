{
  "name": "overmind",
  "owner": {
    "name": "h16rkim",
    "url": "https://github.com/h16rkim"
  },
  "plugins": [
    {
      "name": "kotlin-lsp",
      "source": "./kotlin-lsp",
      "description": "Kotlin language support for Claude Code using JetBrains official Kotlin LSP",
      "version": "1.0.1",
      "author": {
        "name": "h16rkim",
        "email": "h16rkim@gmail.com"
      },
      "homepage": "https://github.com/h16rkim/overmind",
      "repository": "https://github.com/h16rkim/overmind",
      "license": "MIT",
      "keywords": ["kotlin", "lsp", "language-server", "jetbrains", "gradle"],
      "lspServers": {
        "kotlin-lsp": {
          "command": "kotlin-lsp",
          "extensionToLanguage": {
            ".kt": "kotlin",
            ".kts": "kotlin"
          }
        }
      }
    },
    {
      "name": "jdtls",
      "source": "./jdtls",
      "description": "Eclipse JDT Language Server for Java",
      "version": "0.0.1",
      "author": {
        "name": "h16rkim",
        "email": "h16rkim@gmail.com"
      },
      "homepage": "https://github.com/h16rkim/overmind",
      "repository": "https://github.com/h16rkim/overmind",
      "license": "MIT",
      "keywords": ["java", "lsp", "language-server", "eclipse"]
    },
    {
      "name": "typescript-language-server",
      "source": "./typescript-language-server",
      "description": "TypeScript/JavaScript language support for Claude Code using typescript-language-server",
      "version": "0.1.0",
      "author": {
        "name": "h16rkim",
        "email": "h16rkim@gmail.com"
      },
      "homepage": "https://github.com/h16rkim/overmind",
      "repository": "https://github.com/h16rkim/overmind",
      "license": "MIT",
      "keywords": ["typescript", "javascript", "lsp", "language-server"],
      "lspServers": {
        "typescript-language-server": {
          "command": "typescript-language-server",
          "extensionToLanguage": {
            ".ts": "typescript",
            ".tsx": "typescriptreact",
            ".js": "javascript",
            ".jsx": "javascriptreact"
          }
        }
      }
    },
    {
      "name": "mcps",
      "source": "./mcps",
      "description": "MCP servers for Claude Code",
      "version": "0.1.2",
      "author": {
        "name": "h16rkim",
        "email": "h16rkim@gmail.com"
      }
    },
    {
      "name": "blog",
      "source": "./blog",
      "description": "Blog skills for place research, later management, and place management",
      "version": "0.1.4",
      "author": {
        "name": "h16rkim",
        "email": "h16rkim@gmail.com"
      },
      "keywords": ["blog", "kakaomap", "googlemap", "place", "later"]
    }
  ]
}
